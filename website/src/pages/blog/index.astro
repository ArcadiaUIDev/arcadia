---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    title: 'Build a Blazor Dashboard in 10 Minutes — Complete Tutorial',
    description: 'Step-by-step guide to building a SaaS admin dashboard with KPI cards, line charts, bar charts, progress bars, and sparklines using Arcadia Controls.',
    date: '2026-03-24',
    slug: 'blazor-dashboard-tutorial',
    readTime: '10 min read',
    tags: ['Blazor', 'Dashboard', 'Tutorial', '.NET'],
  },
  {
    title: 'Blazor Gauge Component — Build KPI Dashboards with Radial Gauges',
    description: 'How to add semi-circle and full-circle radial gauges to your Blazor app with color thresholds, custom formatting, and live data binding.',
    date: '2026-03-24',
    slug: 'blazor-gauge-component',
    readTime: '8 min read',
    tags: ['Blazor', 'Gauge', 'KPI', 'Dashboard'],
  },
  {
    title: 'Free Blazor Charts — Build Data Visualizations Without Paying a Dime',
    description: 'Stop paying $1000+/year for Blazor chart libraries. Get 4 chart types, 7 dashboard widgets, and an MIT license — completely free.',
    date: '2026-03-24',
    slug: 'free-blazor-charts-2026',
    readTime: '8 min read',
    tags: ['Blazor', 'Charts', 'Free', 'Open Source'],
  },
  {
    title: 'How to Create a Blazor Chart — Step-by-Step Tutorial',
    description: 'The complete guide to adding charts to Blazor. From scratch SVG to full library integration with multi-series, area fill, and interactivity.',
    date: '2026-03-24',
    slug: 'how-to-create-blazor-chart',
    readTime: '12 min read',
    tags: ['Blazor', 'Charts', 'Tutorial', 'SVG'],
  },
  {
    title: 'Best Blazor Chart Libraries in 2026 — Arcadia vs Telerik vs Syncfusion vs MudBlazor',
    description: 'A detailed comparison of features, pricing, bundle size, render modes, and chart types across the top Blazor charting libraries.',
    date: '2026-03-23',
    slug: 'blazor-chart-library-comparison-2026',
    readTime: '10 min read',
    tags: ['Blazor', 'Charts', 'Comparison', '.NET'],
  },
];
---

<Layout title="Blog — Arcadia Controls" description="Technical articles, tutorials, and insights about Blazor UI development, charting, and dashboard design.">

  <section class="pt-32 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-extrabold mb-4">Blog</h1>
      <p class="text-[var(--arc-text-muted)] text-lg mb-12">Technical articles, tutorials, and insights about Blazor UI development.</p>

      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="block glass-card p-8 group">
            <div class="flex items-center gap-3 text-sm text-[var(--arc-text-muted)] mb-3">
              <time>{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
              <span>·</span>
              <span>{post.readTime}</span>
            </div>
            <h2 class="text-2xl font-bold mb-2 group-hover:text-purple-300 transition-colors">{post.title}</h2>
            <p class="text-[var(--arc-text-muted)] leading-relaxed">{post.description}</p>
            <div class="flex gap-2 mt-3">
              {post.tags.map(tag => (
                <span class="text-xs bg-purple-500/10 text-purple-300 px-2 py-0.5 rounded-full">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

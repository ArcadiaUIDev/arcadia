---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Live Demo — Arcadia Controls" description="Try Arcadia Controls components live in your browser. Charts, forms, notifications — all interactive.">

  <section class="pt-28 pb-12 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-4xl font-bold mb-4">
        Try <span class="gradient-text">Arcadia Controls</span> Live
      </h1>
      <p class="text-[var(--arc-text-muted)] text-lg mb-8 max-w-2xl mx-auto">
        All demos run in your browser via Blazor WebAssembly. Click through the tabs to explore charts, forms, and notifications.
      </p>
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="max-w-6xl mx-auto">
      <!-- Demo navigation tabs -->
      <div class="flex gap-2 mb-6 overflow-x-auto" id="demo-tabs">
        <button class="demo-tab active" onclick="switchDemo('/', this)">Home</button>
        <button class="demo-tab" onclick="switchDemo('/charts', this)">Charts</button>
        <button class="demo-tab" onclick="switchDemo('/forms', this)">Forms</button>
        <button class="demo-tab" onclick="switchDemo('/notifications', this)">Notifications</button>
        <button class="demo-tab" onclick="switchDemo('/theme', this)">Theme</button>
      </div>

      <!-- Demo frame -->
      <div style="border: 1px solid rgba(139,92,246,0.2); border-radius: 16px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.4);">
        <div style="display: flex; align-items: center; gap: 6px; padding: 12px 16px; background: rgba(15,8,35,0.9); border-bottom: 1px solid rgba(139,92,246,0.12);">
          <div style="width: 10px; height: 10px; border-radius: 50%; background: #ff5f57;"></div>
          <div style="width: 10px; height: 10px; border-radius: 50%; background: #febc2e;"></div>
          <div style="width: 10px; height: 10px; border-radius: 50%; background: #28c840;"></div>
          <span style="margin-left: 8px; font-size: 0.8rem; color: #9490b3;">Arcadia Demo — Blazor Server</span>
          <a href="http://localhost:5050" target="_blank" style="margin-left: auto; font-size: 0.75rem; color: #8b5cf6; text-decoration: none; opacity: 0.7;">Open in new tab ↗</a>
        </div>
        <iframe id="demo-frame" src="http://localhost:5050/" style="width: 100%; height: 700px; border: none; background: white;"></iframe>
      </div>

      <p class="text-center text-sm text-[var(--arc-text-muted)] mt-6">
        This demo runs the Blazor Server demo app. <code style="background: rgba(139,92,246,0.1); padding: 2px 6px; border-radius: 4px; font-size: 0.85em;">dotnet run --project samples/Arcadia.Demo.Server</code>
      </p>
    </div>
  </section>

  <style>
    .demo-tab {
      padding: 8px 20px;
      border-radius: 10px;
      font-size: 0.875rem;
      font-weight: 500;
      color: #9490b3;
      background: rgba(20, 10, 50, 0.4);
      border: 1px solid rgba(139, 92, 246, 0.15);
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
    }
    .demo-tab:hover {
      color: white;
      border-color: rgba(139, 92, 246, 0.3);
      background: rgba(139, 92, 246, 0.1);
    }
    .demo-tab.active {
      color: white;
      background: linear-gradient(135deg, rgba(139,92,246,0.3), rgba(236,72,153,0.2));
      border-color: rgba(139, 92, 246, 0.4);
    }
  </style>

  <script>
    function switchDemo(route, btn) {
      document.getElementById('demo-frame').src = 'http://localhost:5050' + route;
      document.querySelectorAll('.demo-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    }
  </script>

</Layout>

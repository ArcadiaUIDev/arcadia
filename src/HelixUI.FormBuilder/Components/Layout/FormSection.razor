@namespace HelixUI.FormBuilder.Components.Layout
@inherits HelixUI.Core.Base.HelixComponentBase

<fieldset class="@CssClass" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Title))
    {
        <legend class="helix-form-section__title">
            @if (Collapsible)
            {
                <button type="button"
                        class="helix-form-section__toggle"
                        aria-expanded="@(!_collapsed)"
                        @onclick="ToggleCollapsed">
                    @Title
                    <span class="helix-form-section__chevron" aria-hidden="true">@(_collapsed ? "+" : "−")</span>
                </button>
            }
            else
            {
                @Title
            }
        </legend>
    }

    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="helix-form-section__description">@Description</p>
    }

    @if (!_collapsed)
    {
        <div class="helix-form-section__content" style="@GridStyle">
            @ChildContent
        </div>
    }
</fieldset>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public int Columns { get; set; } = 1;
    [Parameter] public bool Collapsible { get; set; }
    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _collapsed;

    protected override void OnInitialized() => _collapsed = Collapsed;

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private string? GridStyle => Columns > 1
        ? $"display: grid; grid-template-columns: repeat({Columns}, 1fr); gap: var(--helix-spacing-md);"
        : null;

    private string? CssClass => HelixUI.Core.Utilities.CssBuilder.Default("helix-form-section")
        .AddClass("helix-form-section--collapsible", Collapsible)
        .AddClass("helix-form-section--collapsed", _collapsed)
        .AddClass(Class)
        .Build();
}

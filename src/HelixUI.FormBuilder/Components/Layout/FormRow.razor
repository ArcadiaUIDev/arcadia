@namespace HelixUI.FormBuilder.Components.Layout
@inherits HelixUI.Core.Base.HelixComponentBase

<div class="@CssClass" style="@Style" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int Columns { get; set; } = 2;
    [Parameter] public string Gap { get; set; } = "var(--helix-spacing-md)";

    private new string? Style => HelixUI.Core.Utilities.StyleBuilder.Default()
        .AddStyle("display", "grid")
        .AddStyle("grid-template-columns", $"repeat({Columns}, 1fr)")
        .AddStyle("gap", Gap)
        .AddRaw(base.Style)
        .Build();

    private string? CssClass => HelixUI.Core.Utilities.CssBuilder.Default("helix-form-row")
        .AddClass(Class)
        .Build();
}

@namespace HelixUI.FormBuilder.Components.Fields
@inherits FieldBase

<fieldset class="@ContainerClass" @attributes="AdditionalAttributes">
    <legend class="helix-field__label">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="helix-field__required" aria-hidden="true">*</span> }
    </legend>

    <div class="helix-repeater" aria-describedby="@AriaDescribedBy">
        @for (var i = 0; i < Rows.Count; i++)
        {
            var rowIndex = i;
            <div class="helix-repeater__row">
                <div class="helix-repeater__row-fields">
                    @if (RowTemplate is not null)
                    {
                        @RowTemplate(new RepeaterRowContext(rowIndex, Rows[rowIndex]))
                    }
                </div>
                <div class="helix-repeater__row-actions">
                    <button type="button"
                            class="helix-repeater__remove"
                            disabled="@(EffectiveDisabled || Rows.Count <= MinRows)"
                            aria-label="@($"Remove row {rowIndex + 1}")"
                            @onclick="() => RemoveRow(rowIndex)">
                        Remove
                    </button>
                </div>
            </div>
        }

        <button type="button"
                class="helix-repeater__add"
                disabled="@(EffectiveDisabled || (MaxRows.HasValue && Rows.Count >= MaxRows.Value))"
                @onclick="AddRow">
            @AddText
        </button>
    </div>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="helix-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="helix-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="helix-field__error">@error</div>
            }
        </div>
    }
</fieldset>

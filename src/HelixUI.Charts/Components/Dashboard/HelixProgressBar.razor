@namespace HelixUI.Charts.Components.Dashboard
@inherits HelixUI.Core.Base.HelixComponentBase

<div class="@CssClass" role="progressbar"
     aria-valuenow="@Value" aria-valuemin="@Min" aria-valuemax="@Max"
     aria-label="@(Label ?? $"{Percent:F0}%")"
     @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="helix-progress__header">
            <span class="helix-progress__label">@Label</span>
            @if (ShowValue)
            {
                <span class="helix-progress__value">@Value / @Max</span>
            }
        </div>
    }
    <div class="helix-progress__track">
        <div class="helix-progress__fill" style="width: @(Percent)%; background: @FillColor;"></div>
    </div>
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool ShowValue { get; set; } = true;
    [Parameter] public string Color { get; set; } = "primary";

    /// <summary>
    /// Thresholds for color changes. E.g., [(60, "warning"), (90, "danger")].
    /// Values above the threshold use that color.
    /// </summary>
    [Parameter] public IReadOnlyList<(double Threshold, string Color)>? Thresholds { get; set; }

    private double Percent => Max > Min ? Math.Clamp((Value - Min) / (Max - Min) * 100, 0, 100) : 0;

    private string FillColor
    {
        get
        {
            if (Thresholds is not null)
            {
                foreach (var (threshold, color) in Thresholds.OrderByDescending(t => t.Threshold))
                {
                    if (Percent >= threshold)
                        return ResolveColor(color);
                }
            }
            return ResolveColor(Color);
        }
    }

    private static string ResolveColor(string name) => name switch
    {
        "primary" => "var(--helix-color-primary)",
        "success" => "var(--helix-color-success)",
        "warning" => "var(--helix-color-warning)",
        "danger" => "var(--helix-color-danger)",
        "info" => "var(--helix-color-info)",
        _ => name
    };

    private string? CssClass => HelixUI.Core.Utilities.CssBuilder.Default("helix-progress")
        .AddClass(Class)
        .Build();
}

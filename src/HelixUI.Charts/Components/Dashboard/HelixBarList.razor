@namespace HelixUI.Charts.Components.Dashboard
@inherits HelixUI.Core.Base.HelixComponentBase
@typeparam T

<div class="@CssClass" @attributes="AdditionalAttributes">
    @if (Data is not null && NameField is not null && ValueField is not null)
    {
        @foreach (var item in Data)
        {
            var name = NameField(item);
            var value = ValueField(item);
            var percent = _maxValue > 0 ? value / _maxValue * 100 : 0;

            <div class="helix-barlist__item">
                <div class="helix-barlist__bar-bg">
                    <div class="helix-barlist__bar-fill" style="width: @($"{percent:F1}")%; background: @ResolvedColor;"></div>
                </div>
                <div class="helix-barlist__content">
                    <span class="helix-barlist__name">@name</span>
                    <span class="helix-barlist__value">@FormatValue(value)</span>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<T>? Data { get; set; }
    [Parameter] public Func<T, string>? NameField { get; set; }
    [Parameter] public Func<T, double>? ValueField { get; set; }
    [Parameter] public string? ValueFormat { get; set; }
    [Parameter] public string Color { get; set; } = "primary";

    private double _maxValue;

    private string ResolvedColor => Color switch
    {
        "primary" => "var(--helix-color-primary)",
        "success" => "var(--helix-color-success)",
        "warning" => "var(--helix-color-warning)",
        "danger" => "var(--helix-color-danger)",
        "info" => "var(--helix-color-info)",
        _ => Color
    };

    protected override void OnParametersSet()
    {
        if (Data is not null && ValueField is not null)
            _maxValue = Data.Count > 0 ? Data.Max(ValueField) : 0;
    }

    private string FormatValue(double value)
    {
        if (!string.IsNullOrEmpty(ValueFormat))
            return value.ToString(ValueFormat);
        return value.ToString("N0");
    }

    private string? CssClass => HelixUI.Core.Utilities.CssBuilder.Default("helix-barlist")
        .AddClass(Class)
        .Build();
}

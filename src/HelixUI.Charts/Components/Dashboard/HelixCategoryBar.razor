@namespace HelixUI.Charts.Components.Dashboard
@inherits HelixUI.Core.Base.HelixComponentBase
@typeparam T

<div class="@CssClass" role="img" aria-label="@AriaLabel" @attributes="AdditionalAttributes">
    <div class="helix-catbar__bar">
        @if (Data is not null && NameField is not null && ValueField is not null && _total > 0)
        {
            @for (var i = 0; i < Data.Count; i++)
            {
                var item = Data[i];
                var percent = ValueField(item) / _total * 100;
                var color = _palette.GetColor(i);
                <div class="helix-catbar__segment"
                     style="width: @($"{percent:F1}")%; background: @color;"
                     title="@($"{NameField!(item)}: {ValueField!(item):N0}")"></div>
            }
        }
    </div>
    @if (ShowLegend && Data is not null && NameField is not null && ValueField is not null)
    {
        <div class="helix-catbar__legend">
            @for (var i = 0; i < Data.Count; i++)
            {
                var item = Data[i];
                var color = _palette.GetColor(i);
                <span class="helix-catbar__legend-item">
                    <span class="helix-catbar__legend-swatch" style="background: @color;"></span>
                    @NameField(item)
                </span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<T>? Data { get; set; }
    [Parameter] public Func<T, string>? NameField { get; set; }
    [Parameter] public Func<T, double>? ValueField { get; set; }
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public HelixUI.Charts.Core.ChartPalette? Palette { get; set; }

    private HelixUI.Charts.Core.ChartPalette _palette = HelixUI.Charts.Core.ChartPalette.Default;
    private double _total;

    protected override void OnParametersSet()
    {
        _palette = Palette ?? HelixUI.Charts.Core.ChartPalette.Default;
        if (Data is not null && ValueField is not null)
            _total = Data.Sum(ValueField);
    }

    private string? CssClass => HelixUI.Core.Utilities.CssBuilder.Default("helix-catbar")
        .AddClass(Class)
        .Build();
}

@namespace Arcadia.Charts.Components.Dashboard
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<div class="@CssClass" role="progressbar"
     aria-valuenow="@Value" aria-valuemin="@Min" aria-valuemax="@Max"
     aria-label="@(Label ?? $"{Percent:F0}%")"
     @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="arcadia-progress__header">
            <span class="arcadia-progress__label">@Label</span>
            @if (ShowValue)
            {
                <span class="arcadia-progress__value">@Value / @Max</span>
            }
        </div>
    }
    <div class="arcadia-progress__track arcadia-animate-progress">
        <div class="arcadia-progress__fill" style="width: @($"{Percent:F0}")%; background: @FillColor;"></div>
    </div>
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool ShowValue { get; set; } = true;
    [Parameter] public string Color { get; set; } = "primary";

    /// <summary>
    /// Thresholds for color changes. Same GaugeThreshold type used by ArcadiaGaugeChart.
    /// Values above the threshold use that color.
    /// </summary>
    [Parameter] public IReadOnlyList<Arcadia.Charts.Core.GaugeThreshold>? Thresholds { get; set; }

    private double Percent => Max > Min ? Math.Clamp((Value - Min) / (Max - Min) * 100, 0, 100) : 0;

    private string FillColor
    {
        get
        {
            if (Thresholds is not null)
            {
                foreach (var t in Thresholds.OrderByDescending(t => t.Value))
                {
                    if (Percent >= t.Value)
                        return ResolveColor(t.Color);
                }
            }
            return ResolveColor(Color);
        }
    }

    private static string ResolveColor(string name) => name switch
    {
        "primary" => "var(--arcadia-color-primary, #2563eb)",
        "success" => "var(--arcadia-color-success, #16a34a)",
        "warning" => "var(--arcadia-color-warning, #d97706)",
        "danger" => "var(--arcadia-color-danger, #dc2626)",
        "info" => "var(--arcadia-color-info, #0284c7)",
        _ => name
    };

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-progress")
        .AddClass(Class)
        .Build();
}

@namespace Arcadia.Charts.Components.Shared

<div class="arcadia-chart-toolbar">
    <button class="arcadia-chart-toolbar__btn" @onclick="OnExportPng" title="Download as PNG">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arcadia-chart-toolbar__icon"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        PNG
    </button>
    <button class="arcadia-chart-toolbar__btn" @onclick="OnExportSvg" title="Download as SVG">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arcadia-chart-toolbar__icon"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        SVG
    </button>
</div>

@code {
    [Parameter] public EventCallback OnExportPng { get; set; }
    [Parameter] public EventCallback OnExportSvg { get; set; }
}

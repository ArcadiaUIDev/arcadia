@namespace Arcadia.Theme
@inherits Arcadia.Core.Base.ArcadiaComponentBase
@implements IDisposable

<div data-arcadia-theme="@ThemeService.CurrentTheme.Name"
     data-arcadia-density="@Density"
     class="@CssClass"
     style="@ComputedStyle"
     @attributes="AdditionalAttributes">
    <CascadingValue Value="ThemeService" IsFixed="false">
        @ChildContent
    </CascadingValue>
</div>

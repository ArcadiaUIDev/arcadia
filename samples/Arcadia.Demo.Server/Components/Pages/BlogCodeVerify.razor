@page "/blog-verify"
@using Arcadia.Charts.Core
@using Arcadia.Charts.Components.Charts
@using Arcadia.Charts.Components.Dashboard

<h1>Blog Code Verification Page</h1>

<!-- Example 1: Basic line chart -->
<HelixLineChart TItem="MonthlySales"
                Data="@salesData"
                XField="@(d => (object)d.Month)"
                Series="@lineSeries"
                Height="300"
                Width="600"
                Title="Monthly Revenue"
                ShowPoints="true"
                AnimateOnLoad="true" />

<!-- Example 2: Multi-series with area -->
<HelixLineChart TItem="MonthlySales"
                Data="@salesData"
                XField="@(d => (object)d.Month)"
                Series="@multiSeries"
                Height="300"
                Width="600"
                Title="Revenue vs Target" />

<!-- Example 3: Bar chart -->
<HelixBarChart TItem="QuarterData"
               Data="@quarterData"
               XField="@(d => (object)d.Quarter)"
               Series="@barSeries"
               Height="300"
               Width="600"
               Title="Quarterly Sales by Region" />

<!-- Example 4: Pie chart -->
<HelixPieChart TItem="CategorySlice"
               Data="@pieData"
               NameField="@(d => d.Category)"
               ValueField="@(d => d.Amount)"
               Height="300"
               Width="400"
               Title="Revenue by Category"
               InnerRadius="60" />

<!-- Example 5: KPI Cards -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
    <HelixKpiCard Title="Revenue"
                  Value="$142,500"
                  Delta="+12.3%"
                  DeltaType="DeltaType.Increase"
                  Sparkline="@sparkData"
                  Footer="vs last month" />

    <HelixKpiCard Title="Users"
                  Value="8,420"
                  Delta="-2.1%"
                  DeltaType="DeltaType.Decrease"
                  Sparkline="@userSparkData"
                  SparklineColor="danger" />

    <HelixKpiCard Title="Conversion"
                  Value="3.8%"
                  Delta="+0.5%"
                  DeltaType="DeltaType.Increase"
                  Sparkline="@convSparkData"
                  SparklineColor="success" />
</div>

<!-- Example 6: Scatter chart -->
<HelixScatterChart TItem="DataPoint"
                   Data="@scatterData"
                   XField="@(d => d.X)"
                   YField="@(d => d.Y)"
                   Height="300"
                   Width="600"
                   Title="Height vs Weight"
                   Color="primary"
                   PointSize="6" />

<!-- Example 7: Sparkline inline -->
<p>Revenue trend: <HelixSparkline Data="@sparkData" Width="120" Height="32" Color="primary" ShowArea="true" /></p>

@code {
    // Data models
    record MonthlySales(string Month, double Revenue, double Target);
    record QuarterData(string Quarter, double NorthAmerica, double Europe);
    record CategorySlice(string Category, double Amount);
    record DataPoint(double X, double Y);

    // Sparkline data
    double[] sparkData = { 42, 48, 45, 52, 49, 55, 58, 62, 59, 65, 68, 72 };
    double[] userSparkData = { 85, 82, 88, 84, 80, 78, 82, 79, 76, 74, 78, 72 };
    double[] convSparkData = { 2.1, 2.3, 2.5, 2.4, 2.8, 3.0, 2.9, 3.2, 3.4, 3.5, 3.6, 3.8 };

    // Line chart data
    List<MonthlySales> salesData = new()
    {
        new("Jan", 45000, 50000), new("Feb", 52000, 50000),
        new("Mar", 48000, 52000), new("Apr", 61000, 55000),
        new("May", 55000, 55000), new("Jun", 67000, 58000),
        new("Jul", 72000, 60000), new("Aug", 68000, 62000),
        new("Sep", 75000, 65000), new("Oct", 82000, 68000),
        new("Nov", 79000, 70000), new("Dec", 88000, 72000),
    };

    List<SeriesConfig<MonthlySales>> lineSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary" },
    };

    List<SeriesConfig<MonthlySales>> multiSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary", ShowArea = true, AreaOpacity = 0.15 },
        new() { Name = "Target", Field = d => d.Target, Color = "secondary", Dashed = true },
    };

    // Bar chart data
    List<QuarterData> quarterData = new()
    {
        new("Q1", 145000, 98000), new("Q2", 183000, 112000),
        new("Q3", 215000, 134000), new("Q4", 268000, 156000),
    };

    List<SeriesConfig<QuarterData>> barSeries = new()
    {
        new() { Name = "North America", Field = d => d.NorthAmerica, Color = "primary" },
        new() { Name = "Europe", Field = d => d.Europe, Color = "success" },
    };

    // Pie data
    List<CategorySlice> pieData = new()
    {
        new("Enterprise", 68500), new("Pro", 42800),
        new("Starter", 21280), new("Free Trial", 10000),
    };

    // Scatter data
    List<DataPoint> scatterData = Enumerable.Range(0, 30).Select(i =>
    {
        var rng = new Random(i);
        return new DataPoint(150 + rng.NextDouble() * 40, 55 + rng.NextDouble() * 50);
    }).ToList();
}
